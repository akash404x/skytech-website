rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user has admin or editor role
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor'];
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection - users can read their own profile, admins can read all
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Allow users to create/update their own profile, admins can update any
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }
    
    // Products collection - public read, admin write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Services collection - public read, admin write
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Works/Portfolio collection - public read, admin write
    match /works/{workId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Carts collection - users can read/write their own cart
    match /carts/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // Orders collection - users can read their own orders, admins can read/write all
    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      // Only authenticated users can create orders, must set their own userId
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isOwner(resource.data.userId);
    }
    
    // Payments collection - users can read their own payments, admins can read all
    match /payments/{paymentId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated();
    }
    
    // Support chats - users can read their own chats, admins can read all
    match /support-chats/{chatId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      // Users can only create chats for themselves
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isOwner(resource.data.userId);
    }
    
    // Settings collection - only admins can read/write (GST, shipping, delivery settings)
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // Email logs - only admins can read
    match /emailLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }
    
    // Notifications - only admins can read
    match /notifications/{notificationId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }
    
    // Wallet transactions - users can read their own, admins can read all
    match /walletTransactions/{transactionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAdmin();
    }
    
    // Reviews collection - public read of approved reviews, users can create, admins can manage
    match /reviews/{reviewId} {
      // Public can only read approved reviews
      allow read: if resource.data.status == 'approved' || isOwner(resource.data.userId) || isAdmin();
      // Authenticated users can create reviews
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Admins can update reviews (approve/reject)
      allow update: if isAdmin();
    }
  }
}

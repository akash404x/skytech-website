rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user has admin or editor role
    function isAdminOrEditor() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor'];
    }
    
    // Helper function to check if user has admin role only
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper function to check if user has editor role only
    function isEditor() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor';
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection - users can read their own profile, admins can read all
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Allow users to create/update their own profile, admins can update any
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }
    
    // Products collection - public read, only admin can write directly
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Services collection - public read, only admin can write directly
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Works/Portfolio collection - public read, only admin can write directly
    match /works/{workId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Approval requests collection - editors can create, admins can read/update all
    match /approval_requests/{requestId} {
      // Editors can create requests and read their own
      allow create: if isEditor() && request.resource.data.requestedBy.uid == request.auth.uid;
      allow read: if isAdmin() || (isEditor() && resource.data.requestedBy.uid == request.auth.uid);
      // Only admins can approve/reject (update status)
      allow update: if isAdmin();
      // Only admins can delete
      allow delete: if isAdmin();
    }
    
    // Activity logs collection - admins can read/create, editors can read
    match /activity_logs/{logId} {
      allow read: if isAdminOrEditor();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    // Carts collection - users can read/write their own cart
    match /carts/{userId} {
      allow read: if isOwner(userId) || isAdminOrEditor();
      allow write: if isOwner(userId) || isAdminOrEditor();
    }
    
    // Orders collection - users can read their own orders, admins can read/write all
    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdminOrEditor();
      // Only authenticated users can create orders, must set their own userId
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isOwner(resource.data.userId);
    }
    
    // Payments collection - users can read their own payments, admins can read all
    match /payments/{paymentId} {
      allow read: if isOwner(resource.data.userId) || isAdminOrEditor();
      allow create: if isAuthenticated();
    }
    
    // Support chats - users can read their own chats, admins can read all
    match /support-chats/{chatId} {
      allow read: if isOwner(resource.data.userId) || isAdminOrEditor();
      // Users can only create chats for themselves
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isOwner(resource.data.userId);
    }
    
    // Settings collection - only admins can read/write (GST, shipping, delivery settings)
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // Email logs - only admins can read
    match /emailLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }
    
    // Notifications - only admins can read
    match /notifications/{notificationId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }
    
    // Wallet transactions - users can read their own, admins can read all
    match /walletTransactions/{transactionId} {
      allow read: if isOwner(resource.data.userId) || isAdminOrEditor();
      allow create: if isAdmin();
    }
    
    // Reviews collection - public read of approved reviews, users can create, admins can manage
    match /reviews/{reviewId} {
      // Admins can read all reviews (including pending/rejected for moderation)
      // Public can only read approved reviews
      // Users can read their own reviews
      allow read: if isAdmin() || resource.data.status == 'approved' || isOwner(resource.data.userId);
      // Authenticated users can create reviews
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Admins can update reviews (approve/reject/delete)
      allow update, delete: if isAdmin();
    }
    
    // Coupons collection - admins can read/write all, users can validate coupons via API
    match /coupons/{couponId} {
      // Only admins can read/write coupons
      allow read, write: if isAdmin();
    }
    
    // Payment receipts collection - users can read their own receipts, admins can read all
    match /paymentReceipts/{receiptId} {
      allow read: if isOwner(resource.data.userId) || isAdminOrEditor();
      allow create: if isAdmin();
    }
    
    // Invoices collection - users can read their own invoices, admins can read/write all
    match /invoices/{invoiceId} {
      allow read: if isOwner(resource.data.userId) || isAdminOrEditor();
      allow create, update: if isAdmin();
    }
    
    // Newsletter subscribers collection - public create, admin read/delete
    match /newsletter_subscribers/{subscriberId} {
      // Public can create (subscribe) - direct client write
      allow create: if true;
      // Only admins can read/delete
      allow read, delete: if isAdmin();
      // No updates allowed - users can't modify their subscription
    }
  }
}
